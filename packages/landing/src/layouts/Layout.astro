---
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const {
  title = 'TextileCV — AI-Powered Career Toolkit',
  description = 'Tailor resumes, write cover letters, and generate STAR interview answers from your own experience — powered by LangChain, OpenAI, and ChromaDB. Local-first with encrypted API key storage.',
  image = `${base}/icon.png`,
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />

    <link rel="icon" type="image/png" href={`${base}/icon.png`} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  </head>
  <body>
    <header class="header">
      <nav class="container header-nav">
        <a href={`${base}/`} class="logo">
          <img src={`${base}/icon.png`} alt="TextileCV" width="36" height="36" class="logo-icon" />
          <span class="logo-text">TextileCV</span>
        </a>
        <div class="nav-links">
          <a href={`${base}/#features`}>Features</a>
          <a href={`${base}/#stack`}>Tech Stack</a>
          <a href={`${base}/#quickstart`}>Quick Start</a>
          <a href="https://github.com/MinnKhantZ/CareerAgent" target="_blank" rel="noopener" class="nav-gh">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
            GitHub
          </a>
        </div>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="footer">
      <div class="container footer-inner">
        <div class="footer-brand">
          <img src={`${base}/icon.png`} alt="TextileCV" width="26" height="26" class="logo-icon" />
          <span>TextileCV</span>
        </div>
        <div class="footer-links">
          <a href="https://github.com/MinnKhantZ/CareerAgent" target="_blank" rel="noopener">GitHub</a>
          <a href="https://www.npmjs.com/package/textilecv" target="_blank" rel="noopener">npm</a>
          <a href="https://github.com/MinnKhantZ/CareerAgent/blob/master/LICENSE" target="_blank" rel="noopener">MIT License</a>
        </div>
        <p class="footer-copy">&copy; {new Date().getFullYear()} TextileCV. Open source under MIT.</p>
      </div>
    </footer>

    <style is:global>
      .header {
        position: sticky;
        top: 0;
        z-index: 50;
        background: rgba(248, 250, 252, 0.85);
        backdrop-filter: blur(12px);
        border-bottom: 1px solid var(--surface-200);
      }
      .header-nav {
        display: flex;
        align-items: center;
        justify-content: space-between;
        height: 4rem;
      }
      .logo {
        display: flex;
        align-items: center;
        gap: 0.625rem;
        font-weight: 700;
        font-size: 1.25rem;
        color: var(--surface-900);
      }
      .logo-icon {
        border-radius: 6px;
        object-fit: cover;
      }

      .nav-links {
        display: flex;
        align-items: center;
        gap: 1.75rem;
      }
      .nav-links a {
        font-size: 0.9rem;
        font-weight: 500;
        color: var(--surface-600);
        transition: color 0.2s;
      }
      .nav-links a:hover {
        color: var(--primary-600);
      }
      .nav-gh {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        padding: 0.4rem 0.85rem;
        border: 1px solid var(--surface-200);
        border-radius: 0.5rem;
        font-size: 0.85rem !important;
      }
      .nav-gh:hover {
        border-color: var(--primary-300);
        background: var(--primary-50);
      }

      .footer {
        background: var(--surface-900);
        color: var(--surface-300);
        padding: 3rem 0;
      }
      .footer-inner {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1.25rem;
        text-align: center;
      }
      .footer-brand {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-weight: 700;
        font-size: 1.1rem;
        color: #fff;
      }
      .footer-links {
        display: flex;
        gap: 1.5rem;
      }
      .footer-links a {
        font-size: 0.875rem;
        color: var(--surface-400);
        transition: color 0.2s;
      }
      .footer-links a:hover {
        color: var(--primary-400);
      }
      .footer-copy {
        font-size: 0.8rem;
        color: var(--surface-500);
      }

      @media (max-width: 640px) {
        .nav-links a:not(.nav-gh) {
          display: none;
        }
      }
    </style>
  </body>
</html>
